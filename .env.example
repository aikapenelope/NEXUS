# NEXUS Platform Environment Variables
# Copy to .env and fill in your values

# LLM API Keys (required)
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Voyage AI embeddings (required for Mem0 semantic memory)
VOYAGE_API_KEY=pa-...

# Logfire observability (optional — noop if not set)
LOGFIRE_TOKEN=

# Tavily web search (optional — DuckDuckGo used as free fallback)
TAVILY_API_KEY=tvly-...

# OpenAI (required for Graphiti knowledge graph embeddings)
OPENAI_API_KEY=sk-...

# Docker group ID on host (for sandbox containers)
DOCKER_GID=999
